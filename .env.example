# ──────────────────────────────────────────────────────────────
# Variables d'environnement — copier en `.env.local` (ignoré par git).
# Ne JAMAIS committer de secret réel.
# ──────────────────────────────────────────────────────────────

# ── Auth Supabase (voir docs/adr/004-auth-supabase.md) ─────────
# Projet Supabase → Settings → API (clé "publishable", publique par design)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_...."

# ── Google Sheets — compte de service (modules Familles + Assiduité) ──
#  1. console.cloud.google.com → activer "Google Sheets API" (+ Drive)
#  2. IAM & Admin → Comptes de service → créer → Clés → clé JSON
#  3. Partager le Sheet BDD_Asso_CRM avec le client_email en rôle "Éditeur"
GOOGLE_CLIENT_EMAIL="xxxxx@xxxxx.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Requis uniquement par le script de seed autonome (scripts/seed-sheet.mjs) ;
# l'app utilise l'ID en dur dans lib/google-sheets-server.ts.
GOOGLE_SHEET_ID="1bOISBPwoU1xa5R4Um0fRASXKFeclJ8jB3A3CUHBMlI8"
SUPABASE_SERVICE_ROLE_KEY="KEY supabase"